@{
    Layout = "_Layout";
}

<nav class="navbar navbar-expand bg-body-tertiary border-bottom shadow-sm">
    <div class="container">
        <a class="navbar-brand brand" href="/admin">管理后台</a>
        <ul class="navbar-nav ms-auto">
            <li class="nav-item">
                <a class="nav-link" href="/"><i class="bi bi-house-door"></i> 首页</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> 退出</a>
            </li>
        </ul>
    </div>
</nav>

<div class="bg-light" style="min-height:calc(100vh - 56px);display:flex;flex-direction:column;">
    <div class="container pt-3 pb-4 flex-grow-1">
        <form id="adminForm" class="needs-validation" novalidate onsubmit="return false;">
            @Html.AntiForgeryToken()
            <fieldset>
                <div class="admin-legend d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3 pb-2 border-bottom">
                    <span class="fw-semibold">@await RenderSectionAsync("AdminLegend", false)</span>
                </div>

                <div id="loadingSpinner" class="d-flex justify-content-center d-none">
                    <div class="spinner-border text-secondary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>

                @RenderBody()
            </fieldset>
        </form>
    </div>
</div>

@section Style {
    <link href="~/admin.min.css" rel="stylesheet" asp-append-version="true" />
}

@section Script {
    <script src="~/admin.min.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll(".uploadFileBtn").forEach(x => x.addEventListener("click", function () {
            var input = document.createElement('input');
            input.type = 'file';
            input.setAttribute("name", "file");
            input.onchange = e => {
                var file = e.target.files[0];
                let formData = new FormData();
                formData.append("file", file)
                submitRequest("/admin/file-upload", {
                    method: "POST",
                    body: formData,
                    contentType: "",
                    okAction: function (url) {
                        showInfoToast("文件上传成功: " + url);
                        setTimeout(function() { window.location.reload(); }, 2500);
                    }
                });
            }
            input.click();
        }));
    </script>
    @await RenderSectionAsync("Script", false)
}
