@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "新建标签 :: 管理";
}

<div class="admin-form-card">
    <div class="mb-3">
        <label for="name" class="form-label">名称 <span class="text-danger">*</span></label>
        <input type="text" class="form-control" id="name" name="name" placeholder="标签名" autocomplete="off" autofocus required>
        <div class="invalid-feedback">必填</div>
    </div>
    <div class="mb-3">
        <label for="link" class="form-label">链接 <span class="text-danger">*</span></label>
        <input type="text" class="form-control" id="link" name="link" placeholder="tag-link" autocomplete="off" required>
        <div class="form-text">最终地址为 <code>/post/tag#link-xxx</code></div>
        <div class="invalid-feedback">必填</div>
    </div>
    <div class="mb-3">
        <label for="description" class="form-label">描述</label>
        <textarea class="form-control" id="description" name="description" rows="2" placeholder="可选描述"></textarea>
    </div>
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic">
        <label class="form-check-label" for="isPublic">公开</label>
    </div>
    <button type="submit" class="btn btn-dark w-100">保存标签</button>
</div>

@section AdminLegend {
    <span>新建标签</span>
}

@section Script {
    <script>
        var form = document.querySelector("#adminForm");
        form.addEventListener("submit", function(e) {
            e.preventDefault(); e.stopPropagation();
            var formData = new FormData(form);
            submitRequest("/admin/tag-add", { form: form, method: "PUT", body: new URLSearchParams(formData), contentType: "application/x-www-form-urlencoded" });
        });
    </script>
}
