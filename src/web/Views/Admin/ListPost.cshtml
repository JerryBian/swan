@inject ISwanService _service
@{
    Layout = "_LayoutAdmin";
    var allPosts = await _service.FindAsync<SwanPost>(true);
    ViewData["Title"] = "文章列表 :: 管理";
}

<div class="admin-toolbar">
    <input type="search" class="form-control form-control-sm" placeholder="搜索文章..." />
    <button class="btn btn-outline-secondary btn-sm" id="searchBtn">搜索</button>
    <span class="admin-toolbar-sep"></span>
    <select class="form-select form-select-sm" id="sortSelect" style="width:auto;">
        <option value="data-sort-date">按日期</option>
        <option value="data-sort-hit">按访问</option>
    </select>
    <label class="form-check form-switch" style="white-space:nowrap;font-size:0.85rem;">
        <input class="form-check-input" type="checkbox" id="filterShowPublic" checked> 仅公开
    </label>
    <a class="btn btn-dark btn-sm ms-auto" href="/admin/post-add">+ 新建</a>
</div>

<div class="small text-muted mb-2">
    @allPosts.Count 篇文章 · @allPosts.Count(x => x.IsPublicToEveryOne()) 篇公开
</div>

<div class="admin-list-card" id="listWrapper">
    @foreach (var item in allPosts)
    {
        var rowStyle = item.IsDeleted ? "admin-item-deleted" : (item.IsPublicToEveryOne() ? "" : "bg-warning-subtle");
        <div class="admin-list-item @rowStyle" data-sort-hit="@item.PageStat.Hit" data-sort-date="@item.PublishDate.Ticks" data-filter-is-public="@item.IsPublicToEveryOne()">
            <div class="item-main">
                <div class="post-meta-row">
                    <a href="/post/archive#year-@item.PublishDate.Year">@item.PublishDate.ToCnDate()</a>
                    <span> &middot; </span>
                    <span>@item.PageStat.Hit 次访问</span>
                    @if (item.IsDeleted)
                    {
                        <span> &middot; </span>
                        <span class="text-danger">已删除</span>
                    }
                </div>
                <a href="@item.GetFullLink()" style="@(item.IsDeleted ? "text-decoration:line-through;" : "font-weight:600;")">@item.Title</a>
            </div>
            <div class="item-actions">
                <a class="btn btn-outline-secondary btn-sm" href="/admin/post-edit/@item.Id">编辑</a>
            </div>
        </div>
    }
</div>

@section AdminLegend {
    <span>文章列表</span>
}

@section Script{
    <script>
        const searchEle = document.querySelector("input[type='search']");
        const filterShowPublicEle = document.querySelector("#filterShowPublic");
        const sortSelect = document.querySelector("#sortSelect");
        const filterFunc = function(x) {
            return filterShowPublicEle.checked ? x.getAttribute("data-filter-is-public") === "@bool.TrueString" : true;
        };
        const doSearch = function() {
            searchChildren("#listWrapper", searchEle.value, filterFunc, sortSelect.value);
        };
        searchEle.addEventListener("keyup", function(e) { if (e.key === "Enter") { e.preventDefault(); doSearch(); } });
        document.querySelector("#searchBtn").addEventListener("click", function(e) { e.preventDefault(); doSearch(); });
        sortSelect.addEventListener("change", doSearch);
        filterShowPublicEle.addEventListener("change", doSearch);
        doSearch();
    </script>
}
