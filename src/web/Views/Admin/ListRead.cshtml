@inject ISwanService _service
@{
    Layout = "_LayoutAdmin";
    var readItems = await _service.FindAsync<SwanRead>(true);
    ViewData["Title"] = "阅读列表 :: 管理";
}

<div class="admin-toolbar">
    <input type="search" class="form-control form-control-sm" placeholder="搜索..." />
    <button class="btn btn-outline-secondary btn-sm" id="searchBtn">搜索</button>
    <span class="admin-toolbar-sep"></span>
    <label class="form-check form-switch" style="white-space:nowrap;font-size:0.85rem;">
        <input class="form-check-input" type="checkbox" id="filterShowPublic" checked> 仅公开
    </label>
    <a class="btn btn-dark btn-sm ms-auto" href="/admin/read-add">+ 新建</a>
</div>

<div class="small text-muted mb-2">
    @readItems.Count 本，@readItems.Count(x => x.IsPublic) 本公开
</div>

<div class="admin-list-card" id="listWrapper">
    @foreach (var item in readItems)
    {
        var privateStyle = item.IsPublicToEveryOne() ? "" : "bg-warning-subtle";
        <div class="admin-list-item @privateStyle" data-sort-date="@item.CreatedAt.Ticks" data-filter-is-public="@item.IsPublicToEveryOne()">
            <div class="item-main">
                <span class="item-meta me-2">@item.CreatedAt.ToDate()</span>
                <a href="@item.GetFullLink()" style="font-weight:600;">@item.BookName</a>
                <span class="item-meta ms-2">@Html.Raw(item.HtmlMetadata)</span>
            </div>
            <div class="item-actions">
                <a class="btn btn-outline-secondary btn-sm" href="/admin/read-edit/@item.Id">编辑</a>
            </div>
        </div>
    }
</div>

@section AdminLegend {
    <span>阅读列表</span>
}

@section Script{
    <script>
        var searchEle = document.querySelector("input[type='search']");
        var filterEl = document.querySelector("#filterShowPublic");
        var filterFunc = function(x) { return filterEl.checked ? x.getAttribute("data-filter-is-public") === "@bool.TrueString" : true; };
        var doSearch = function() { searchChildren("#listWrapper", searchEle.value, filterFunc, "data-sort-date"); };
        searchEle.addEventListener("keyup", function(e) { if (e.key === "Enter") { e.preventDefault(); doSearch(); } });
        document.querySelector("#searchBtn").addEventListener("click", function(e) { e.preventDefault(); doSearch(); });
        filterEl.addEventListener("change", doSearch);
        doSearch();
    </script>
}
