@inject ISwanService _service
@model SwanPost
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "编辑文章 :: 管理";
}

<div class="row">
    <div class="col-md-8">
        <div class="admin-form-card">
            <div class="mb-3">
                <label for="title" class="form-label">标题 <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="title" name="title" value="@Model.Title" autocomplete="off" autofocus required>
                <div class="invalid-feedback">必填</div>
            </div>
            <div class="mb-3">
                <label for="link" class="form-label">链接 <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text small text-muted">/post/</span>
                    <input type="text" class="form-control" id="link" name="link" value="@Model.Link" autocomplete="off" required>
                </div>
                <div class="form-text"><code>/post/@(Model.Link).html</code></div>
                <div class="invalid-feedback">必填</div>
            </div>
            <div class="mb-3">
                <label for="content" class="form-label">内容 <span class="text-danger">*</span></label>
                <textarea id="content"></textarea>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-form-card">
            <div class="form-label fw-semibold mb-3">文章设置</div>

            <div class="mb-3">
                <label for="series" class="form-label">系列</label>
                <select class="form-select form-select-sm" id="series" name="series">
                    <option value="">-- 无 --</option>
                    @foreach (var item in await _service.FindAsync<PostSeries>(true))
                    {
                        <option selected="@(Model.Series == item.Id)" value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label for="tags" class="form-label">标签</label>
                <select class="form-select form-select-sm" id="tags" name="tags" multiple size="6">
                    @foreach (var item in await _service.FindAsync<PostTag>(true))
                    {
                        <option selected="@(Model.Tags.Contains(item.Id))" value="@item.Id">@item.Name</option>
                    }
                </select>
                <div class="form-text">按住 Ctrl/Cmd 多选</div>
            </div>

            <div class="mb-3">
                <label for="publishDate" class="form-label">发布日期</label>
                <input type="date" class="form-control form-control-sm" id="publishDate" name="publishDate" value="@Model.PublishDate.ToDate()">
            </div>

            <hr>

            <div class="mb-2">
                <label for="excerpt" class="form-label">摘要</label>
                <textarea class="form-control form-control-sm" id="excerpt" name="excerpt" rows="2">@Model.Excerpt</textarea>
            </div>

            <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic" checked="@Model.IsPublic">
                <label class="form-check-label" for="isPublic">公开发布</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="isDeleted" name="isDeleted" checked="@Model.IsDeleted">
                <label class="form-check-label" for="isDeleted">标记删除</label>
            </div>

            <button type="submit" class="btn btn-dark w-100">保存修改</button>
        </div>
    </div>
</div>

<input type="hidden" name="id" value="@Model.Id" />


@section AdminLegend {
    <span>编辑文章</span>
}

@section Script {
    <script>
        const form = document.querySelector("#adminForm");
        const contentEl = document.querySelector("#content");
        var editor = createEditor(contentEl, "admin_blog_post_edit_@Model.Id");
        form.addEventListener("submit", function(e) {
            e.preventDefault(); e.stopPropagation();
            var formData = new FormData(form);
            formData.append("content", editor.value());
            submitRequest("/admin/post-edit", { form: form, method: "POST", body: new URLSearchParams(formData), contentType: "application/x-www-form-urlencoded" });
        });
        submitRequest("/admin/post-get?id=@Model.Id", {
            method: "POST", okAction: function(x) { editor.value(x.content); }
        });
    </script>
}
