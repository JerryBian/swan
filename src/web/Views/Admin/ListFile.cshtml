@model List<StaticFileItem>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "文件列表 :: 管理";
    var totalSize = Model.Sum(x => x.Size);
    var sizeLabel = totalSize >= 1024 * 1024 ? $"{totalSize / (1024.0 * 1024.0):F1} MB" :
                    totalSize >= 1024 ? $"{totalSize / 1024.0:F1} KB" : $"{totalSize} B";
    var yearGroups = Model
        .GroupBy(f => string.IsNullOrEmpty(f.PathYear) ? "其他" : f.PathYear)
        .OrderBy(g => g.Key == "其他" ? 1 : 0)
        .ThenByDescending(g => g.Key);
    var isFirst = true;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <span class="small text-muted">@Model.Count 个文件，共 @sizeLabel</span>
    <button class="btn btn-dark btn-sm uploadFileBtn"><i class="bi bi-cloud-upload"></i> 上传文件</button>
</div>

@if (Model.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-folder2-open" style="font-size:3rem;"></i>
        <p class="mt-2">还没有上传任何文件</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <tbody>
                @foreach (var yearGroup in yearGroups)
                {
                    var collapseId = "year-" + yearGroup.Key;
                    <tr class="table-light" role="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="@(isFirst ? "true" : "false")" style="cursor:pointer;">
                        <td colspan="4">
                            <i class="bi @(isFirst ? "bi-chevron-down" : "bi-chevron-right") collapse-icon me-1 small"></i>
                            <span class="fw-semibold">@yearGroup.Key</span>
                            <span class="small text-muted ms-2">@yearGroup.Count() 个文件</span>
                        </td>
                    </tr>

                    foreach (var file in yearGroup.OrderByDescending(f => f.LastModified))
                    {
                        <tr class="collapse @(isFirst ? "show" : "")" id="@collapseId">
                            <td>
                                <a href="@file.RelativePath" target="_blank" class="text-decoration-none text-break small">
                                    @if (file.Extension is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".svg" or ".bmp")
                                    {
                                        <i class="bi bi-file-image text-primary me-1"></i>
                                    }
                                    else if (file.Extension is ".pdf")
                                    {
                                        <i class="bi bi-file-pdf text-danger me-1"></i>
                                    }
                                    else if (file.Extension is ".zip" or ".rar" or ".7z" or ".tar" or ".gz")
                                    {
                                        <i class="bi bi-file-zip text-warning me-1"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-file-earmark text-secondary me-1"></i>
                                    }
                                    @file.RelativePath
                                </a>
                            </td>
                            <td class="small text-muted text-nowrap" style="width:80px">@file.SizeFormatted</td>
                            <td class="small text-muted text-nowrap" style="width:90px">@file.LastModified.ToString("MM-dd HH:mm")</td>
                            <td class="text-nowrap" style="width:90px">
                                <button class="btn btn-outline-secondary btn-sm copy-btn" data-url="@file.RelativePath" title="复制链接">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                                <a href="@file.RelativePath" class="btn btn-outline-secondary btn-sm" target="_blank" title="预览/下载">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </td>
                        </tr>
                    }

                    isFirst = false;
                }
            </tbody>
        </table>
    </div>
}

@section AdminLegend {
    <span>文件列表</span>
}

@section Script {
    <script>
        document.querySelectorAll("[data-bs-toggle=\"collapse\"]").forEach(el => {
            el.addEventListener("click", function() {
                var icon = this.querySelector(".collapse-icon");
                if (icon) {
                    var expanded = this.getAttribute("aria-expanded") === "true";
                    icon.classList.toggle("bi-chevron-down", !expanded);
                    icon.classList.toggle("bi-chevron-right", expanded);
                }
            });
        });

        document.querySelectorAll(".copy-btn").forEach(btn => {
            btn.addEventListener("click", function(e) {
                e.stopPropagation();
                var url = window.location.origin + this.getAttribute("data-url");
                navigator.clipboard.writeText(url).then(function() {
                    showInfoToast("链接已复制: " + url);
                }).catch(function() {
                    showErrorToast("复制失败，请手动复制");
                });
            });
        });
    </script>
}
