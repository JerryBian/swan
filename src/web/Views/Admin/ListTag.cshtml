@inject ISwanService _service
@{
    Layout = "_LayoutAdmin";
    var allTags = await _service.FindAsync<PostTag>(true);
    ViewData["Title"] = "标签列表 :: 管理";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <span class="small text-muted">@allTags.Count 个标签，@allTags.Count(x => x.IsPublicToEveryOne()) 个公开</span>
    <a class="btn btn-dark btn-sm" href="/admin/tag-add">+ 新建标签</a>
</div>

<div class="admin-list-card">
    @foreach (var item in allTags)
    {
        var privateStyle = item.IsPublicToEveryOne() ? "" : "bg-warning-subtle";
        <div class="admin-list-item @privateStyle">
            <div class="item-main">
                <a href="@item.GetFullLink()" style="font-weight:600;">@item.Name</a>
                <span class="item-meta ms-2">@item.BlogPosts.Count 篇文章，@item.BlogPosts.Sum(x => x.PageStat.Hit) 次访问</span>
            </div>
            <div class="item-actions">
                <a class="btn btn-outline-secondary btn-sm" href="/admin/tag-edit/@item.Id">编辑</a>
            </div>
        </div>
    }
</div>

@section AdminLegend {
    <span>标签列表</span>
}
