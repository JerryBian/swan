@inject ISwanLogService _swanLogService
@using Microsoft.Extensions.Logging
@{
    Layout = "_LayoutAdmin";
    var logs = await _swanLogService.GetAsync();
    ViewData["Title"] = "查看日志 :: 管理";
}

<div class="small text-muted mb-3">
    近30天 · Debug: @logs.Count(x => x.Level == LogLevel.Debug.ToString()) &middot;
    Info: @logs.Count(x => x.Level == LogLevel.Information.ToString()) &middot;
    Warning: @logs.Count(x => x.Level == LogLevel.Warning.ToString()) &middot;
    Error: @logs.Count(x => x.Level == LogLevel.Error.ToString())
</div>

@foreach (var day in logs.GroupBy(x => x.CreatedAt.Date).OrderByDescending(x => x.Key))
{
    <div class="admin-form-card mb-3">
        <h5 class="mb-1">@day.Key.ToCnDate()</h5>
        <div class="small text-muted mb-3">
            Debug: @day.Count(x => x.Level == LogLevel.Debug.ToString()) &middot;
            Info: @day.Count(x => x.Level == LogLevel.Information.ToString()) &middot;
            Warning: @day.Count(x => x.Level == LogLevel.Warning.ToString()) &middot;
            Error: @day.Count(x => x.Level == LogLevel.Error.ToString())
        </div>
        @foreach (var log in day.OrderByDescending(x => x.CreatedAt))
        {
            var level = log.Level;
            var logClass = level == LogLevel.Error.ToString() ? "log-entry-error"
                : level == LogLevel.Warning.ToString() ? "log-entry-warning"
                : level == LogLevel.Information.ToString() ? "log-entry-info"
                : "log-entry-debug";
            var badgeClass = level == LogLevel.Error.ToString() ? "text-bg-danger"
                : level == LogLevel.Warning.ToString() ? "text-bg-warning"
                : level == LogLevel.Information.ToString() ? "text-bg-info"
                : "text-bg-light";
            <div class="log-entry @logClass">
                <div class="log-entry-head">
                    <span>@log.CreatedAt.ToString("HH:mm:ss")</span>
                    <span class="badge @badgeClass">@level</span>
                </div>
                <div class="log-entry-msg">@log.Message</div>
                @if (!string.IsNullOrEmpty(log.Error))
                {
                    <pre class="log-entry-stack">@log.Error</pre>
                }
            </div>
        }
    </div>
}

@section AdminLegend {
    <span>系统日志</span>
}
