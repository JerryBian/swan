@inject ISwanService _service
@{
    Layout = "_LayoutAdmin";
    var allSeries = await _service.FindAsync<PostSeries>(true);
    ViewData["Title"] = "系列列表 :: 管理";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <span class="small text-muted">@allSeries.Count 个系列，@allSeries.Count(x => x.IsPublicToEveryOne()) 个公开</span>
    <a class="btn btn-dark btn-sm" href="/admin/series-add">+ 新建系列</a>
</div>

<div class="admin-list-card">
    @foreach (var item in allSeries)
    {
        var privateStyle = item.IsPublicToEveryOne() ? "" : "bg-warning-subtle";
        <div class="admin-list-item @privateStyle">
            <div class="item-main">
                <a href="@item.GetFullLink()" style="font-weight:600;">@item.Name</a>
                <span class="item-meta ms-2">@item.BlogPosts.Count 篇文章，@item.BlogPosts.Sum(x => x.PageStat.Hit) 次访问</span>
            </div>
            <div class="item-actions">
                <a class="btn btn-outline-secondary btn-sm" href="/admin/series-edit/@item.Id">编辑</a>
            </div>
        </div>
    }
</div>

@section AdminLegend {
    <span>系列列表</span>
}
