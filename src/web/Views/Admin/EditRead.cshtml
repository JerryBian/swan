@inject ISwanService _swanService
@model SwanRead
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "编辑阅读 :: 管理";
}

<div class="row">
    <div class="col-md-8">
        <div class="admin-form-card">
            <div class="mb-3">
                <label for="bookName" class="form-label">书名 <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="bookName" name="bookName" value="@Model.BookName" autocomplete="off" autofocus required>
                <div class="invalid-feedback">必填</div>
            </div>
            <div class="mb-3">
                <label for="author" class="form-label">作者 <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="author" name="author" value="@Model.Author" autocomplete="off" required>
                <div class="invalid-feedback">必填</div>
            </div>
            <div class="mb-3">
                <label for="comment" class="form-label">评论</label>
                <textarea id="comment"></textarea>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-form-card">
            <div class="form-label fw-semibold mb-3">阅读设置</div>

            <div class="mb-3">
                <label for="authorCountry" class="form-label">作者国籍</label>
                <input type="text" class="form-control form-control-sm" id="authorCountry" name="authorCountry" value="@Model.AuthorCountry">
            </div>
            <div class="mb-3">
                <label for="translator" class="form-label">译者</label>
                <input type="text" class="form-control form-control-sm" id="translator" name="translator" value="@Model.Translator">
            </div>
            <div class="mb-3">
                <label for="posts" class="form-label">关联文章</label>
                <select class="form-select form-select-sm" id="posts" name="posts" multiple size="6">
                    @foreach (var p in await _swanService.FindAsync<SwanPost>(true))
                    {
                        <option selected="@(Model.Posts.Contains(p.Id))" value="@p.Id">@p.Title</option>
                    }
                </select>
                <div class="form-text">按住 Ctrl/Cmd 多选</div>
            </div>
            <div class="mb-3">
                <label for="grade" class="form-label">评分</label>
                <select class="form-select form-select-sm" id="grade" name="grade">
                    <option value="0" selected="@(Model.Grade == 0)">一般</option>
                    <option value="1" selected="@(Model.Grade == 1)">好评</option>
                    <option value="-1" selected="@(Model.Grade == -1)">差评</option>
                </select>
            </div>
            <hr>
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic" checked="@Model.IsPublic">
                <label class="form-check-label" for="isPublic">公开</label>
            </div>
            <button type="submit" class="btn btn-dark w-100">保存修改</button>
        </div>
    </div>
</div>

<input type="hidden" name="id" value="@Model.Id" />

@section AdminLegend {
    <span>编辑阅读</span>
}

@section Script {
    <script>
        var form = document.querySelector("#adminForm");
        var commentEl = document.querySelector("#comment");
        var editor = createEditor(commentEl, "admin_read_edit_@Model.Id");
        var txt = document.createElement("textarea");
        txt.innerHTML = "@Html.Raw(Model.Comment)";
        editor.value(txt.value);
        form.addEventListener("submit", function(e) {
            e.preventDefault(); e.stopPropagation();
            var formData = new FormData(form);
            formData.append("comment", editor.value());
            submitRequest("/admin/read-edit", { form: form, method: "POST", body: new URLSearchParams(formData), contentType: "application/x-www-form-urlencoded" });
        });
    </script>
}
