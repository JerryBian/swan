@inject ISwanService _service
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "新建文章 :: 管理";
}

<div class="row">
    <div class="col-md-8">
        <div class="admin-form-card">
            <div class="mb-3">
                <label for="title" class="form-label">标题 <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="title" name="title" placeholder="文章标题" autocomplete="off" autofocus required>
                <div class="invalid-feedback">必填</div>
            </div>
            <div class="mb-3">
                <label for="link" class="form-label">链接 <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text small text-muted">/post/</span>
                    <input type="text" class="form-control" id="link" name="link" placeholder="article-slug" autocomplete="off" required>
                </div>
                <div class="form-text">URL 友好字符，如 <code>my-article</code>，最终地址为 <code>/post/my-article.html</code></div>
                <div class="invalid-feedback">必填</div>
            </div>
            <div class="mb-3">
                <label for="content" class="form-label">内容 <span class="text-danger">*</span></label>
                <textarea id="content"></textarea>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="admin-form-card">
            <div class="form-label fw-semibold mb-3">文章设置</div>

            <div class="mb-3">
                <label for="series" class="form-label">系列</label>
                <select class="form-select form-select-sm" id="series" name="series">
                    <option selected value="">-- 无 --</option>
                    @foreach (var item in await _service.FindAsync<PostSeries>(true))
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label for="tags" class="form-label">标签</label>
                <select class="form-select form-select-sm" id="tags" name="tags" multiple size="6">
                    @foreach (var item in await _service.FindAsync<PostTag>(true))
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
                <div class="form-text">按住 Ctrl/Cmd 多选</div>
            </div>

            <div class="mb-3">
                <label for="publishDate" class="form-label">发布日期</label>
                <input type="date" class="form-control form-control-sm" id="publishDate" name="publishDate" value="@DateTime.Today.ToDate()">
            </div>

            <hr>

            <div class="mb-2">
                <label for="excerpt" class="form-label">摘要</label>
                <textarea class="form-control form-control-sm" id="excerpt" name="excerpt" rows="2" placeholder="留空则自动提取首段"></textarea>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic">
                <label class="form-check-label" for="isPublic">公开发布</label>
            </div>

            <button type="submit" class="btn btn-dark w-100">保存文章</button>
        </div>
    </div>
</div>


@section AdminLegend {
    <span>新建文章</span>
}

@section Script {
    <script>
        var form = document.querySelector("#adminForm");
        var contentEl = document.querySelector("#content");
        var editor = createEditor(contentEl, "admin_blog_post_add");

        // Auto-generate link slug from title
        var titleEl = document.querySelector("#title");
        var linkEl = document.querySelector("#link");
        var linkTouched = false;
        titleEl.addEventListener("input", function() {
            if (!linkTouched && !linkEl.value) {
                linkEl.value = titleEl.value
                    .replace(/[^\w一-鿿-]/g, '-')
                    .replace(/-+/g, '-')
                    .replace(/^-|-$/g, '')
                    .toLowerCase() || titleEl.value;
            }
        });
        linkEl.addEventListener("input", function() { linkTouched = true; });

        form.addEventListener("submit", function(e) {
            e.preventDefault(); e.stopPropagation();
            var formData = new FormData(form);
            formData.append("content", editor.value());
            submitRequest("/admin/post-add", { form: form, method: "PUT", body: new URLSearchParams(formData), contentType: "application/x-www-form-urlencoded" });
        });
    </script>
}
