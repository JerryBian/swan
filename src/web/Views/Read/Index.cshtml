@inject ISwanService _swanService
@model IEnumerable<IGrouping<int, SwanRead>>
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "近期阅读";
    ViewData["EnableSEO"] = bool.TrueString;
    ViewData["Url"] = "/read";
    ViewData["Description"] = "近期阅读";
}

<div data-bs-spy="scroll" data-bs-target="#archiveIndex" data-bs-smooth-scroll="true">
    @foreach (var year in Model.OrderByDescending(x => x.Key))
    {
        <div class="section-card">
            <div class="section-card-header">
                <h4 class="section-card-title" id="year-@year.Key"><i class="bi bi-book"></i> @year.Key</h4>
                <span class="section-card-count">@year.Count() 本</span>
            </div>
            <div class="section-card-body">
                @foreach (var book in year)
                {
                    var privateStyle = book.IsPublicToEveryOne() ? "" : "bg-warning-subtle";
                    var hasContent = !string.IsNullOrEmpty(book.HtmlComment) || book.BlogPosts.Any();

                    <div class="read-row @privateStyle">
                        <span class="read-row-date">@book.CreatedAt.ToCnDate(true)</span>

                        <div class="read-row-main">
                            @if (hasContent)
                            {
                                <a class="inline-expand" href="javascript:;" onclick="toggleInline(this)" data-target="book-@book.Id">
                                    @book.BookName
                                </a>
                            }
                            else
                            {
                                <span class="read-row-name">@book.BookName</span>
                            }

                            @if (book.Grade > 0)
                            {
                                <i class="bi bi-hand-thumbs-up read-grade-up" title="好评"></i>
                            }
                            else if (book.Grade < 0)
                            {
                                <i class="bi bi-hand-thumbs-down read-grade-down" title="差评"></i>
                            }
                        </div>

                        <span class="read-row-meta">@Html.Raw(book.HtmlMetadata)</span>

                        @if (hasContent)
                        {
                            <div class="inline-expand-content" id="book-@book.Id">
                                @if (!string.IsNullOrEmpty(book.HtmlComment))
                                {
                                    <div class="post read-comment">
                                        @Html.Raw(book.HtmlComment)
                                    </div>
                                }
                                @if (book.BlogPosts.Any())
                                {
                                    <div class="read-linked-posts">
                                        <span class="read-linked-label">相关文章</span>
                                        @foreach (var post in book.BlogPosts)
                                        {
                                            <a href="@post.GetFullLink()" class="read-article-link">@post.Title</a>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Aside{
    <div class="card" id="archiveIndex">
        <div class="card-header">
            <span class="pb-1 border-bottom border-dark pe-2 text-truncate">
                <i class="bi bi-book-half"></i> 阅读索引
            </span>
        </div>
        <div class="list-group">
            @foreach (var year in Model.OrderByDescending(x => x.Key))
            {
                <a href="#year-@year.Key" class="list-group-item list-group-item-action"><i class="bi bi-book"></i> @year.Key 年</a>
            }
        </div>
    </div>
}

@section Script{
    <script>
        setActive(document.querySelector("#navbarRead"));
        document.addEventListener('DOMContentLoaded', function () {
            anchors.options = {
                placement: "right",
                visible: "hover",
                icon: "¶",
                base: "/read",
                class: "text-reset"
            };
            anchors.add("h4, h5");
        });

        function toggleInline(el) {
            var target = document.getElementById(el.dataset.target);
            if (target) {
                target.classList.toggle('open');
            }
        }
    </script>
}
