@model IEnumerable<PostSeries>
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "文章系列";
    ViewData["EnableSEO"] = bool.TrueString;
    ViewData["Url"] = "/post/series";
    ViewData["Description"] = "文章系列";
}

<div data-bs-spy="scroll" data-bs-target="#seriesIndex" data-bs-smooth-scroll="true">
    @foreach (var item in Model.OrderByDescending(x => x.BlogPosts.Any() ? x.BlogPosts.Max(p => p.PublishDate) : DateTime.MinValue))
    {
        <div class="section-card">
            <div class="section-card-header">
                <h4 class="section-card-title" id="link-@item.Link"><i class="bi bi-bookmark"></i> @item.Name</h4>
                <span class="section-card-count">@item.BlogPosts.Count() 篇</span>
            </div>
            @if (!string.IsNullOrEmpty(item.Description))
            {
                <div class="section-card-desc">@item.Description</div>
            }
            <div class="section-card-body">
                @foreach (var post in item.BlogPosts.OrderByDescending(x => x.PublishDate))
                {
                    var privateStyle = post.IsPublicToEveryOne() ? "" : "bg-warning-subtle";
                    <div class="section-item @privateStyle">
                        <span class="section-item-date">@post.PublishDate.ToCnDate()</span>
                        <a href="@post.GetFullLink()" class="section-item-link">@post.Title</a>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Aside{
    <div class="card" id="seriesIndex">
        <div class="card-header">
            <span class="pb-1 border-bottom border-dark pe-2 text-truncate">
                <i class="bi bi-bookmarks"></i> 系列索引
            </span>
        </div>
        <div class="list-group">
            @foreach (var item in Model)
            {
                <a href="#link-@item.Link" class="list-group-item list-group-action"><i class="bi bi-bookmark"></i> @item.Name</a>
            }
        </div>
    </div>
}

@section Script{
    <script>
        setActive(document.querySelector("#navbarSeries"));
        document.addEventListener('DOMContentLoaded', function () {
            anchors.options = {
                placement: "right",
                visible: "hover",
                icon: "¶",
                base: "/post/series",
                class: "text-reset"
            };
            anchors.add("h4, h5");
        });
    </script>
}
