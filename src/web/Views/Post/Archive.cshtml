@inject ISwanService _swanService
@model IEnumerable<IGrouping<int, SwanPost>>
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "文章存档";
    ViewData["EnableSEO"] = bool.TrueString;
    ViewData["Url"] = "/post/archive";
    ViewData["Description"] = "所有文章存档";
}

<div data-bs-spy="scroll" data-bs-target="#archiveIndex" data-bs-smooth-scroll="true">
    @foreach (var item in Model.OrderByDescending(x => x.Key))
    {
        <div class="section-card">
            <div class="section-card-header">
                <h4 class="section-card-title" id="year-@item.Key"><i class="bi bi-folder2"></i> @item.Key</h4>
                <span class="section-card-count">@item.Count() 篇</span>
            </div>
            <div class="section-card-body">
                @foreach (var post in item.OrderByDescending(x => x.PublishDate))
                {
                    var privateStyle = post.IsPublicToEveryOne() ? "" : "bg-warning-subtle";
                    <div class="section-item @privateStyle">
                        <span class="section-item-date">@post.PublishDate.ToCnDate(true)</span>
                        <a href="@post.GetFullLink()" class="section-item-link">@post.Title</a>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Aside{
    <div class="card" id="archiveIndex">
        <div class="card-header">
            <span class="pb-1 border-bottom border-dark pe-2 text-truncate">
                <i class="bi bi-archive-fill"></i> 存档索引
            </span>
        </div>
        <div class="list-group">
            @foreach (var item in Model.OrderByDescending(x => x.Key))
            {
                <a href="#year-@item.Key" class="list-group-item list-group-item-action"><i class="bi bi-folder2"></i> @item.Key 年</a>
            }
        </div>
    </div>
}

@section Script{
    <script>
        setActive(document.querySelector("#navbarPost"));
        document.addEventListener('DOMContentLoaded', function () {
            anchors.options = {
                placement: "right",
                visible: "hover",
                icon: "¶",
                base: "/post/archive",
                class: "text-reset"
            };
            anchors.add("h4, h5");
        });
    </script>
}
