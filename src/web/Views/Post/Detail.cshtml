@inject ISwanService _swanService
@inject IOptions<SwanOption> _option
@model SwanPost
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = Model.Title;
    var privateStyle = Model.IsDeleted ? "admin-item-deleted" : (Model.IsPublicToEveryOne() ? "" : "bg-warning-subtle");
    ViewData["EnableSEO"] = bool.TrueString;
    ViewData["Url"] = Model.GetFullLink();
    ViewData["Description"] = Model.TextExcerpt;
}

<div class="@privateStyle">
    @Html.Raw(Model.HtmlMetadata1)
    <h2 class="large-title" style="font-size:1.45rem;font-weight:700;@(Model.IsDeleted ? "text-decoration:line-through;" : "")">@Model.Title</h2>
    @if (Model.IsDeleted)
    {
        <span class="text-danger small">此文章已删除</span>
    }

    <article class="mt-4 mb-3 post">
        @Html.Raw(Model.HtmlContent)
    </article>

    @Html.Raw(Model.HtmlMetadata2)

    <div class="license-box">
        &copy; @Model.PublishDate.Year @_option.Value.Title. 原创文章，未经许可请勿转载、摘编或镜像。电子邮箱： <a href="mailto:@_option.Value.ContactEmail"></a>。
    </div>
</div>

@section Aside{
    @if (Model.RecommendPostsByTag.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <span class="pb-1 border-bottom border-dark pe-2 text-truncate"><i class="bi bi-tags-fill"></i> 推荐文章</span>
            </div>
            <div class="list-group">
                @foreach (var item in Model.RecommendPostsByTag)
                {
                    <a href="@item.GetFullLink()" class="list-group-item list-group-action">
                        <i class="bi bi-hash"></i>@item.Title
                    </a>
                }
            </div>
        </div>
    }

    @if (Model.RecommendPostsBySeries.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <span class="pb-1 border-bottom border-dark pe-2 text-truncate"><i class="bi bi-bookmarks-fill"></i> 系列文章</span>
            </div>
            <div class="list-group">
                @foreach (var item in Model.RecommendPostsBySeries)
                {
                    if (item.Id == Model.Id)
                    {
                        <div class="list-group-item" style="font-weight:600;">
                            <i class="bi bi-hash"></i>@item.Title
                        </div>
                    }
                    else
                    {
                        <a href="@item.GetFullLink()" class="list-group-item list-group-action">
                            <i class="bi bi-hash"></i>@item.Title
                        </a>
                    }
                }
            </div>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <span class="pb-1 border-bottom border-dark pe-2 text-truncate"><i class="bi bi-info-circle-fill"></i> 文章信息</span>
        </div>
        <div class="list-group">
            @if (Model.PreviousPost != null)
            {
                <a href="@Model.PreviousPost.GetFullLink()" class="list-group-item list-group-action"><i class="bi bi-arrow-left-short"></i> @Model.PreviousPost.Title</a>
            }
            @if (Model.NextPost != null)
            {
                <a href="@Model.NextPost.GetFullLink()" class="list-group-item list-group-action"><i class="bi bi-arrow-right-short"></i> @Model.NextPost.Title</a>
            }
            <div class="list-group-item sidebar-timestamp"><i class="bi bi-clock"></i> 修改于 @Model.LastUpdatedAt.ToCnDate()</div>
        </div>
    </div>
}

@section Style{
    @if (Model.PreviousPost != null)
    {
        <link rel="previous" href="@Model.PreviousPost.GetFullLink()">
    }
    @if (Model.NextPost != null)
    {
        <link rel="next" href="@Model.NextPost.GetFullLink()">
    }
}

@section Script{
    <script>
        setActive(document.querySelector("#navbarPost"));
        document.addEventListener('DOMContentLoaded', function (event) {
            hljs.highlightAll();
            anchors.options = {
                placement: "right",
                visible: "hover",
                icon: "¶",
                base: "@Model.GetFullLink()",
                class: "text-reset"
            };
            anchors.add("h4, h5");
        });
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
}
